# ─────────────────────────────────────────────────────────────────────────────
# HACKATHON PROJECT — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_SECRET_KEY=change-me-32-chars-min
DEBUG=true
LOG_LEVEL=INFO

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=StudyPulse

# ── Database (Postgres) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hackathon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hackathon
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# ── Vector DB (RAG) ───────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=hackathon-index
# OR use local ChromaDB:
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hackathon-uploads
AWS_RDS_ENDPOINT=
AWS_EKS_CLUSTER_NAME=hackathon-cluster

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCS_BUCKET=hackathon-gcs-uploads
GCP_SQL_INSTANCE=hackathon-sql
GKE_CLUSTER_NAME=hackathon-gke
GOOGLE_APPLICATION_CREDENTIALS=./infra/terraform/gcp/service-account.json

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local           # local | s3 | gcs
STORAGE_LOCAL_PATH=./storage/uploads

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
