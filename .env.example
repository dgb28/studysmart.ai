# ─────────────────────────────────────────────────────────────────────────────
# HACKATHON PROJECT — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_SECRET_KEY=change-me-32-chars-min
DEBUG=true
LOG_LEVEL=INFO

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=StudyPulse

# ── Database (Postgres) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hackathon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hackathon
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=bkbjbkhvCTgvyGCUTgb.hfCJT$$kg&
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# If email is “already registered” but login fails, reset app password (replace email/password):
#   docker compose exec backend python scripts/reset_user_password.py "your@email.com" "YourNewPassword123"
# Dev DB bootstrap (tables + test user only — no bundled courses):
#   docker compose exec backend python scripts/seed_data.py
# Remove legacy catalog subjects from DB (user_id IS NULL):
#   docker compose exec backend python scripts/clear_catalog_subjects.py

